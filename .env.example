# Akosha Environment Configuration
# Copy this file to .env and customize as needed for your development environment

# Storage Configuration
# Hot tier: DuckDB in-memory + Redis cache (0-7 days, real-time search)
AKOSHA_HOT_PATH="/data/akosha/hot"

# Warm tier: DuckDB on-disk (7-90 days, historical analytics)
AKOSHA_WARM_PATH="/data/akosha/warm"

# Cold tier: Parquet files in cloud storage (90+ days, archival)
AKOSHA_COLD_BUCKET="akosha-cold-data"

# Redis Configuration (caching layer)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_DB="0"

# Oneiric Storage Configuration (cold tier backend)
ONEIRIC_STORAGE_BACKEND="s3"
S3_BUCKET="akosha-cold-data"
S3_REGION="us-west-2"

# API Configuration
AKOSHA_API_PORT="8000"
AKOSHA_MCP_PORT="3001"

# Development Configuration
AKOSHA_DEBUG="false"
AKOSHA_LOG_LEVEL="INFO"
